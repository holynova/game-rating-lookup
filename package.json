{
  "name": "game-tier",
  "version": "1.0.1",
  "description": "A CLI for looking up Steam review scores and Xiaoheihe ratings by game name.",
  "private": false,
  "type": "module",
  "bin": {
    "game-tier": "bin/game-tier.js"
  },
  "files": [
    "bin",
    "src",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "start": "node server.js",
    "dev": "node server.js",
    "test": "node --test",
    "prepack": "npm test && node scripts/check-help.js",
    "pack:dry": "npm pack --dry-run",
    "worker:dev": "wrangler dev",
    "worker:deploy": "wrangler deploy"
  },
  "engines": {
    "node": ">=18"
  },
  "keywords": [
    "steam",
    "xiaoheihe",
    "game",
    "rating",
    "cli"
  ],
  "homepage": "https://github.com/holynova/game-rating-lookup#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/holynova/game-rating-lookup.git"
  },
  "bugs": {
    "url": "https://github.com/holynova/game-rating-lookup/issues"
  },
  "license": "MIT"
}
